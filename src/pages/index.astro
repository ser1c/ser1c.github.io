---
import Layout from "../layouts/Layout.astro";
import {Content as About} from '../components/md/about.md';
import SocialItems from "../components/MenuBar/SocialItems.astro";
---

<Layout>
  <main>


    <!-- Photo and About with Nepal-inspired styling -->
<article
class="flex flex-col gap-y-size-md md:gap-y-0 md:flex-row md:gap-x-size-md"
>
<div class="max-w-[14rem] lg:max-w-[18rem] mx-auto flex flex-col">
  <div class="aspect-square overflow-hidden rounded-full shadow-md">
    <img
      src="/images/headshot_small.jpeg"
      alt="Headshot of Sabin Subedi"
      class="w-full h-full object-cover"
    />
  </div>
  <!-- Social links below photo with additional gap/margin -->
  <div class="mt-4">
    <SocialItems variant="profile" />
  </div>
</div>

<div class="prose flow">
  <h1 class="text-size-5 !text-size-5 font-bold !text-black dark:!text-white">
    Sabin Subedi
  </h1>
  <About></About>
  <a
    href="/files/CV.pdf"
    class="inline-block mt-6 px-5 py-2.5 bg-kelly-500 text-white font-semibold rounded-md hover:bg-kelly-600 transition-colors duration-200"
  >
    Download CV →
  </a>
</div>
</article>

<!-- Open to Opportunities Section -->
<section class="mt-size-lg pt-size-md border-t border-zinc-200 dark:border-zinc-700">
  <div class="prose">
    <h2 class="text-size-1 font-bold text-kelly-600 dark:text-kelly-400">👋 Open to Opportunities</h2>
    <p class="text-size--1">I'm currently on the job market and open to conversations about postdoctoral positions, faculty roles, and policy-oriented research positions in development and health economics.</p>
    <p class="text-size--1 text-zinc-600 dark:text-zinc-400">
      <strong>Get in touch:</strong> <a href="mailto:sabinsubedi.subedi@gmail.com">sabinsubedi.subedi@gmail.com</a>
      · <a href="https://www.linkedin.com/in/sabin-subedi-007575134/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      · <a href="https://github.com/ser1c" target="_blank" rel="noopener noreferrer">GitHub</a>
      · <a href="https://substack.com/@sabinsubedi" target="_blank" rel="noopener noreferrer">Substack</a>
    </p>
  </div>
</section>